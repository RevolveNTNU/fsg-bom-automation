# ─────────────────────────────────────────────────────────
# FSG CCBOM Automation — Configuration
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is excluded via .gitignore.
# ─────────────────────────────────────────────────────────

# ── FSG Login Credentials ────────────────────────────────
# Your personal login for https://www.formulastudent.de
FSG_USERNAME=your_fsg_username
FSG_PASSWORD=your_fsg_password

# ── Team Configuration ───────────────────────────────────
# Your team ID from the FSG BOM URL:
#   https://www.formulastudent.de/teams/fse/details/bom/tid/YOUR_ID
# Example: ELBFLORACE = 359
# Set to YOUR team ID (required) — e.g. TEAM_ID=359
TEAM_ID=YOUR_TEAM_ID

# ── Behaviour ────────────────────────────────────────────
# TEST_MODE: Set to 'true' to upload only the first few parts.
#            Always start with test mode to verify setup!
TEST_MODE=true

# TEST_LIMIT: How many parts to upload in test mode (default: 3).
TEST_LIMIT=3

# DRY_RUN: If true, do not perform any uploads — only log what would happen.
# Useful to verify parsing & dedup without touching the website.
DRY_RUN=false

# DEFAULT_SYSTEM: Skip the interactive system selection menu.
#   Leave empty to be prompted every run, or set to one of:
#     AT  — Autonomous System
#     BR  — Brake System
#     DT  — Drivetrain
#     ET  — Engine and Tractive System
#     FR  — Chassis and Body
#     LV  — Grounded Low Voltage System
#     MS  — Miscellaneous Fit and Finish
#     ST  — Steering System
#     SU  — Suspension System
#     WT  — Wheels, Wheel Bearings and Tires
#   Set to 'ALL' to process every system at once.
DEFAULT_SYSTEM=

# ALLOWED_ASSEMBLIES: Optional comma-separated exact assembly labels from the
# FSG website. If set, only rows which resolve to these exact labels will be
# uploaded. Example:
# ALLOWED_ASSEMBLIES=Calipers,Brake Discs,Brake Pads
# Leave empty to be prompted with a numbered checklist after login.
ALLOWED_ASSEMBLIES=

# ── Paths ────────────────────────────────────────────────
# BOMS_DIR: Folder where your Excel files live (default: BOMs)
BOMS_DIR=BOMs

# LOG_FILE: Name of the log output file (default: bom_log.txt)
LOG_FILE=bom_log.txt

# Website field limits:
#   part         = 25 characters max
#   part_comments = 40 characters max
# Rows exceeding these limits are skipped and logged as errors.

# ── Rate Limiting (Server Safety) ────────────────────────
# BASE_DELAY: Standard randomized delay between parts (seconds).
BASE_DELAY=2.0

# BURST_LIMIT: Number of parts before taking a longer randomized break.
BURST_LIMIT=5

# BURST_COOLDOWN: Duration of the long break (seconds).
BURST_COOLDOWN=15.0

# ── Robustness & Timeouts ────────────────────────────────
# MAX_RETRIES: Automatic retries for flaky actions before asking the user.
MAX_RETRIES=2

# REQUEST_TIMEOUT: Browser timeout for finding elements (seconds).
REQUEST_TIMEOUT=30.0
