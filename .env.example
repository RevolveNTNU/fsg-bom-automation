# FSG CCBOM Automation Configuration
# Copy this file to .env and fill in your details.

# 🔑 Credentials
# Recommended: Set these once, or use --set-password to store them securely.
FSG_USERNAME=your_username
FSG_PASSWORD=your_password

# 🚀 Core Configuration
# The ID at the end of your BOM page URL: .../details/bom/tid/359
TEAM_ID=YOUR_TEAM_ID

# 🛠 Behaviour
# TEST_MODE: true (default) is safer for testing.
TEST_MODE=true
# DRY_RUN: true prevents all write operations to the FSG website.
DRY_RUN=true
# Number of parts to process when TEST_MODE=true
TEST_LIMIT=3

# ⚙ Optional Filters - can be left empty to to choose via CLI
# Pre-select a system code (e.g. BR, DT, SU, etc.)
DEFAULT_SYSTEM=
# Comma-separated list of exact assembly names to allow (e.g. "Calipers,Dampers")
ALLOWED_ASSEMBLIES=

# 📂 Paths & Logs
BOMS_DIR=BOMs
LOG_FILE=bom_log.txt

# ⏱ Performance & Robustness
# Delay in seconds between part uploads
BASE_DELAY=2.0
# Number of uploads before triggering a cooldown
BURST_LIMIT=10
# Cooldown duration in seconds after burst
BURST_COOLDOWN=15.0
# Max retries per part on failure
MAX_RETRIES=2
# Request timeout in seconds
REQUEST_TIMEOUT=30.0
